# DevSul API
DEVSUL_API_URL=https://api.lnsoft.com.br/devsul/integracao/atendimentos/resumo
DEVSUL_BEARER_TOKEN=

# ÁtomosChat (Helena é apenas a referência técnica; o deploy real é Atomos)
ATOMOS_BASE_URL=http://api.chat.atomos.tech
ATOMOS_SEND_ENDPOINT=/chat/v1/message/send

# Token permanente de autenticação (formato: pn_xxxxxxx).
# Criar em: Nacional > Ajustes > Integracoes > Integracao via API
ATOMOS_BEARER_TOKEN=

# ID/Token do canal aprovado pela Meta (UUID). Usado como remetente (from).
ATOMOS_CHANNEL_ID=

# ID do template de mensagem a ser disparado
ATOMOS_TEMPLATE_ID=6b5df_notafiscal

# Modo de teste (RF.03)
TEST_PHONE_NUMBER=5581999430696
TEST_MODE=true

# Janela de busca DevSul (dias para trás a partir de hoje)
DEVSUL_LOOKBACK_DAYS=30

# Filtro de situações da DevSul (string única por enquanto; formato a validar)
DEVSUL_SITUACOES=1282

# Delay entre envios em ms (RF.05)
SEND_DELAY_MS=1000

# Limite de envios por rodada. 0 = sem limite (produção).
# Use 1 para testar só o primeiro disparo antes de liberar a carga inteira.
MAX_SENDS_PER_RUN=0

# Agendamento cron (RF.06). Deixe vazio para rodar apenas manualmente.
# Ex: "0 9 * * *" = todo dia às 09:00
CRON_SCHEDULE=

# Auto-conclusão de conversa após envio (PUT /chat/v1/session/{id}/complete)
# Liga o worker que, decorrido o delay, encerra a sessão da Atomos para liberar a janela.
ATOMOS_AUTOCOMPLETE_ENABLED=true
# Tempo de espera (ms) entre o envio e o disparo do complete. Default 70s.
ATOMOS_AUTOCOMPLETE_DELAY_MS=70000
# Se true, conversa concluída reabre automaticamente quando o contato responder depois.
ATOMOS_AUTOCOMPLETE_REACTIVATE=true
# Se true, interrompe chatbot em execução ao concluir.
ATOMOS_AUTOCOMPLETE_STOP_BOT=false

# Ambiente (development | production | test)
NODE_ENV=development

# === Banco de dados ===
# Em dev local: SQLite (descomentar a primeira linha).
# Em produção/Vercel: Postgres (Neon). Vercel↔Neon integration injeta automaticamente.
# DATABASE_URL="file:./prisma/dev.db"
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.sa-east-1.aws.neon.tech/nacional?sslmode=require&pgbouncer=true&connection_limit=1
# DIRECT_URL é usada pelo Prisma só durante `migrate` (não tolera pgbouncer).
DIRECT_URL=postgresql://user:pass@ep-xxx.sa-east-1.aws.neon.tech/nacional?sslmode=require

# === Autenticação (NextAuth + Google) ===
# URL base da app. Em dev: http://localhost:3000. Em prod: a URL pública.
NEXTAUTH_URL=http://localhost:3000
# Secret usado pra assinar JWTs. Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=
# Credenciais OAuth do Google Cloud Console (Web Application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Lista CSV de emails autorizados a acessar (sem espaços).
ALLOWED_EMAILS=your@email.com
