# DevSul API
DEVSUL_API_URL=https://api.lnsoft.com.br/devsul/integracao/atendimentos/resumo
DEVSUL_BEARER_TOKEN=

# ÁtomosChat (Helena é apenas a referência técnica; o deploy real é Atomos)
ATOMOS_BASE_URL=http://api.chat.atomos.tech
ATOMOS_SEND_ENDPOINT=/chat/v1/message/send

# Token permanente de autenticação (formato: pn_xxxxxxx).
# Criar em: Nacional > Ajustes > Integracoes > Integracao via API
ATOMOS_BEARER_TOKEN=

# ID/Token do canal aprovado pela Meta (UUID). Usado como remetente (from).
ATOMOS_CHANNEL_ID=

# ID do template de mensagem a ser disparado
ATOMOS_TEMPLATE_ID=6b5df_notafiscal

# Modo de teste (RF.03)
TEST_PHONE_NUMBER=5581999430696
TEST_MODE=true

# Janela de busca DevSul (dias para trás a partir de hoje)
DEVSUL_LOOKBACK_DAYS=30

# Filtro de situações da DevSul (string única por enquanto; formato a validar)
DEVSUL_SITUACOES=1282

# Delay entre envios em ms (RF.05)
SEND_DELAY_MS=1000

# Limite de envios por rodada. 0 = sem limite (produção).
# Use 1 para testar só o primeiro disparo antes de liberar a carga inteira.
MAX_SENDS_PER_RUN=0

# Agendamento cron (RF.06). Deixe vazio para rodar apenas manualmente.
# Ex: "0 9 * * *" = todo dia às 09:00
CRON_SCHEDULE=

# Ambiente (development | production | test)
NODE_ENV=development

# Banco local SQLite. A migração do Prisma criará dev.db automaticamente.
DATABASE_URL="file:./prisma/dev.db"
